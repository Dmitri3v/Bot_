```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
.env
.env.local
.env.*

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
.coverage
htmlcov/
coverage/

# IDE specific files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Build artifacts
dist/
build/
target/
*.egg-info/

# Testing
.pytest_cache/
.mypy_cache/
.tox/

# Compression artifacts
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```